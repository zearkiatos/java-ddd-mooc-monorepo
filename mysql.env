# Database Configuration
MYSQL_DATABASE=mooc

# User Configuration - Use strong passwords in production
MYSQL_USER=mooc_user
MYSQL_PASSWORD=SecureP@ssw0rd123!
MYSQL_ROOT_PASSWORD=RootSecureP@ssw0rd456!

# Security Configuration
MYSQL_RANDOM_ROOT_PASSWORD=false
MYSQL_ONETIME_PASSWORD=false

# Performance and Security Settings
MYSQL_INNODB_BUFFER_POOL_SIZE=128M
MYSQL_MAX_CONNECTIONS=100
MYSQL_QUERY_CACHE_SIZE=0
MYSQL_QUERY_CACHE_TYPE=0

# Logging Configuration for security monitoring
MYSQL_LOG_BIN=mysql-bin
MYSQL_BINLOG_FORMAT=ROW
MYSQL_EXPIRE_LOGS_DAYS=7
