							"const { v4: uuidv4 } = require('uuid'); // Import the uuid library",
							"",
							"pm.environment.set(\"COURSE_UUID\", uuidv4());"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"My course\",\n    \"duration\": \"21 H\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
